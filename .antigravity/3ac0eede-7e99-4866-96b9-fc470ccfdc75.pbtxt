 <header class=\\\"h-24 border-b border-[#DEDCD7] flex items-center justify-between px-10 bg-white\\\">\\n    <div class=\\\"flex flex-col\\\">\\n      <span class=\\\"text-[10px] tracking-[0.2em] font-bold text-[#8C8A84] uppercase\\\">Assessment Framework</span>\\n      <h1 class=\\\"text-3xl font-serif italic font-medium tracking-tight\\\">IELTS Feedback Engine <span class=\\\"text-[#C5A059]\\\">v2.4</span></h1>\\n    </div>\\n    <div class=\\\"flex gap-12 text-right\\\">\\n      <div>\\n        <p class=\\\"text-[10px] uppercase tracking-widest text-[#8C8A84]\\\">Submission ID</p>\\n        <p class=\\\"font-mono text-sm font-bold\\\">#UK-2024-881290</p>\\n      </div>\\n      <div>\\n        <p class=\\\"text-[10px] uppercase tracking-widest text-[#8C8A84]\\\">Timestamp</p>\\n        <p class=\\\"font-mono text-sm font-bold\\\">23 OCT 2024 / 14:02</p>\\n      </div>\\n    </div>\\n  </header>\\n\\n  <!-- Main Content Grid -->\\n  <main class=\\\"flex-1 grid grid-cols-12 gap-0 overflow-hidden\\\">\\n    \\n    <!-- LEFT: Input Summary -->\\n    <aside class=\\\"col-span-3 border-r border-[#DEDCD7] p-8 flex flex-col justify-between bg-white/50\\\">\\n      <div>\\n        <div class=\\\"mb-8\\\">\\n          <h2 class=\\\"text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059] mb-4\\\">Submission Data</h2>\\n          <div class=\\\"p-4 border border-[#EBE9E4] bg-white rounded-sm\\\">\\n            <p class=\\\"text-xs leading-relaxed text-[#555] italic mb-4\\\">\\n              \\\"The global crisis regarding environmental degradation requires a multi-national response rather than isolated efforts...\\\"\\n            </p>\\n            <div class=\\\"flex justify-between items-center\\\">\\n              <span class=\\\"text-[10px] font-mono bg-[#F0EFEC] px-2 py-1\\\">Word Count: 284</span>\\n              <span class=\\\"text-[10px] font-mono bg-[#F0EFEC] px-2 py-1 uppercase\\\">Task 2 / Writing</span>\\n            </div>\\n          </div>\\n        </div>\\n\\n        <div class=\\\"space-y-4\\\">\\n          <h2 class=\\\"text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059]\\\">Candidate Details</h2>\\n          <p class=\\\"text-sm border-b border-[#EBE9E4] pb-2\\\">Name: <span class=\\\"font-bold\\\">Sofia G. Moretti</span></p>\\n          <p class=\\\"text-sm border-b border-[#EBE9E4] pb-2\\\">Target Band: <span class=\\\"font-bold\\\">8.0</span></p>\\n          <p class=\\\"text-sm\\\">Attempt: <span class=\\\"font-bold\\\">03 (Mock)</span></p>\\n        </div>\\n      </div>\\n\\n      <div class=\\\"mt-auto\\\">\\n        <div class=\\\"p-4 bg-[#1A1A1A] text-white text-xs\\\">\\n          <p class=\\\"opacity-60 mb-1 font-mono\\\">SYSTEM STATUS</p>\\n          <p class=\\\"font-bold\\\">Audit Complete. Matrix Generated.</p>\\n        </div>\\n      </div>\\n    </aside>\\n\\n    <!-- CENTER: Analytics Layer (Data Visualization) -->\\n    <section class=\\\"col-span-5 p-10 flex flex-col gap-8\\\">\\n      <div class=\\\"flex items-end gap-6\\\">\\n        <div class=\\\"w-32 h-32 rounded-full border-4 border-[#C5A059] flex items-center justify-center bg-white shadow-xl\\\">\\n          <span class=\\\"text-5xl font-serif font-bold italic tracking-tighter\\\">7.5</span>\\n        </div>\\n        <div class=\\\"pb-2\\\">\\n          <h2 class=\\\"text-4xl font-serif tracking-tight\\\">Overall Band</h2>\\n          <p class=\\\"text-[#8C8A84] text-sm uppercase tracking-widest\\\">Estimated Public Score</p>\\n        </div>\\n      </div>\\n\\n      <div class=\\\"grid grid-cols-2 gap-4 flex-1\\\">\\n        <!-- Score Tiles -->\\n        <div class=\\\"p-6 bg-white border border-[#DEDCD7] flex flex-col justify-between hover:border-[#C5A059] transition-colors\\\">\\n          <p class=\\\"text-[10px] uppercase font-bold text-[#8C8A84] tracking-widest\\\">Task Achievement</p>\\n          <div class=\\\"flex items-baseline justify-between\\\">\\n            <span class=\\\"text-4xl font-mono\\\">8.0</span>\\n            <div class=\\\"w-16 h-1 bg-[#F0EFEC]\\\"><div class=\\\"w-[88%] h-full bg-[#C5A059]\\\"></div></div>\\n          </div>\\n        </div>\\n        \\n        <div class=\\\"p-6 bg-white border border-[#DEDCD7] flex flex-col justify-between\\\">\\n          <p class=\\\"text-[10px] uppercase font-bold text-[#8C8A84] tracking-widest\\\">Coherence & Cohesion</p>\\n          <div class=\\\"flex items-baseline justify-between\\\">\\n            <span class=\\\"text-4xl font-mono\\\">7.0</span>\\n            <div class=\\\"w-16 h-1 bg-[#F0EFEC]\\\"><div class=\\\"w-[77%] h-full bg-[#C5A059]\\\"></div></div>\\n          </div>\\n        </div>\\n\\n        <div class=\\\"p-6 bg-white border border-[#DEDCD7] flex flex-col justify-between\\\">\\n          <p class=\\\"text-[10px] uppercase font-bold text-[#8C8A84] tracking-widest\\\">Lexical Resource</p>\\n          <div class=\\\"flex items-baseline justify-between\\\">\\n            <span class=\\\"text-4xl font-mono\\\">7.5</span>\\n            <div class=\\\"w-16 h-1 bg-[#F0EFEC]\\\"><div class=\\\"w-[83%] h-full bg-[#C5A059]\\\"></div></div>\\n          </div>\\n        </div>\\n\\n        <div class=\\\"p-6 bg-white border border-[#DEDCD7] flex flex-col justify-between\\\">\\n          <p class=\\\"text-[10px] uppercase font-bold text-[#8C8A84] tracking-widest\\\">Grammatical Range</p>\\n          <div class=\\\"flex items-baseline justify-between\\\">\\n            <span class=\\\"text-4xl font-mono\\\">7.0</span>\\n            <div class=\\\"w-16 h-1 bg-[#F0EFEC]\\\"><div class=\\\"w-[77%] h-full bg-[#C5A059]\\\"></div></div>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n\\n    <!-- RIGHT: Data Output Layer (Corrections) -->\\n    <section class=\\\"col-span-4 bg-[#1A1A1A] p-8 text-white flex flex-col\\\">\\n      <div class=\\\"mb-8 border-b border-white/10 pb-4 flex justify-between items-baseline\\\">\\n        <h2 class=\\\"text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059]\\\">Correction Matrix</h2>\\n        <span class=\\\"text-[10px] font-mono opacity-40\\\">JSON:EXPORT</span>\\n      </div>\\n\\n      <div class=\\\"flex-1 space-y-6\\\">\\n        <div class=\\\"group\\\">\\n          <div class=\\\"flex gap-3 mb-2\\\">\\n            <span class=\\\"text-[#C5A059] font-mono text-xs mt-1\\\">01</span>\\n            <p class=\\\"text-sm font-medium\\\">Lexical Variation needed for \\\"environment\\\".</p>\\n          </div>\\n          <p class=\\\"ml-7 text-xs text-white/50 leading-relaxed\\\">Suggested: \'Ecological landscape\', \'Biosphere\', or \'Natural habitat\' to avoid repetition.</p>\\n        </div>\\n\\n        <div class=\\\"group\\\">\\n          <div class=\\\"flex gap-3 mb-2\\\">\\n            <span class=\\\"text-[#C5A059] font-mono text-xs mt-1\\\">02</span>\\n            <p class=\\\"text-sm font-medium\\\">Subject-verb agreement error in Paragraph 2.</p>\\n          </div>\\n          <p class=\\\"ml-7 text-xs text-white/50 leading-relaxed text-red-400 font-mono\\\">- \\\"The range of problems require...\\\" \342\206\222 \\\"The range of problems requires...\\\"</p>\\n        </div>\\n\\n        <div class=\\\"group\\\">\\n          <div class=\\\"flex gap-3 mb-2\\\">\\n            <span class=\\\"text-[#C5A059] font-mono text-xs mt-1\\\">03</span>\\n            <p class=\\\"text-sm font-medium\\\">Logical flow enhancement required.</p>\\n          </div>\\n          <p class=\\\"ml-7 text-xs text-white/50 leading-relaxed\\\">Use cohesive devices like \'Furthermore\' or \'Consequently\' to bridge ideas between sentences 3 and 4.</p>\\n        </div>\\n\\n        <div class=\\\"group\\\">\\n          <div class=\\\"flex gap-3 mb-2\\\">\\n            <span class=\\\"text-[#C5A059] font-mono text-xs mt-1\\\">04</span>\\n            <p class=\\\"text-sm font-medium\\\">Stronger thesis statement suggested.</p>\\n          </div>\\n          <p class=\\\"ml-7 text-xs text-white/50 leading-relaxed\\\">The introduction is too passive. Explicitly state your stance to secure a Band 8+ in Task Achievement.</p>\\n        </div>\\n      </div>\\n\\n      <button class=\\\"mt-auto w-full py-4 border border-[#C5A059] text-[#C5A059] uppercase tracking-[0.3em] text-[10px] font-bold hover:bg-[#C5A059] hover:text-white transition-all\\\">\\n        Generate PDF Report\\n      </button>\\n    </section>\\n  </main>\\n\\n  <!-- Footer Bar -->\\n  <footer class=\\\"h-12 border-t border-[#DEDCD7] bg-white flex items-center px-10 justify-between\\\">\\n    <p class=\\\"text-[9px] uppercase tracking-widest text-[#8C8A84]\\\">\302\251 2024 Global IELTS Analytics Engine. Proprietary Scoring Algorithm.</p>\\n    <div class=\\\"flex gap-6\\\">\\n      <span class=\\\"w-2 h-2 rounded-full bg-green-500\\\"></span>\\n      <span class=\\\"text-[9px] uppercase tracking-widest text-[#1A1A1A]\\\">System: Operational</span>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
